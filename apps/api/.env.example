# Database
DATABASE_URL=postgres://koin:koin@localhost:5432/koin

# Auth — RS256 key pair
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then set each as a single-line string with literal \n for newlines:
#   JWT_PRIVATE_KEY="$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem)"
#   JWT_PUBLIC_KEY="$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' public.pem)"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth
# Register at https://console.cloud.google.com
# Authorised redirect URI must exactly match GOOGLE_REDIRECT_URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# App
APP_URL=http://localhost:5173
NODE_ENV=development
PORT=3000
